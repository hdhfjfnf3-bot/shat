# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Environment Variables — Vercel + Supabase Deployment
# Copy this to .env for local dev, add to Vercel dashboard for production
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# ── Supabase (Public — safe to expose to browser) ──
# Supabase Dashboard → Settings → API → Project URL
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Supabase Dashboard → Settings → API → anon / public key
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Supabase (Secret — only for Vercel serverless functions) ──
# Supabase Dashboard → Settings → API → service_role / secret key
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── JWT Secret ─────────────────────────────────────
# Any long random string (32+ characters)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-at-least-32-characters-long
