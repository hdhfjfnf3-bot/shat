# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Backend (api-server) Environment Variables
# Copy this file to .env and fill in your values
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# ── Supabase PostgreSQL connection string ──────────
# Get from: Supabase Dashboard → Settings → Database → Connection string (URI mode)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# ── JWT Secret ─────────────────────────────────────
# Use a long random string (minimum 32 characters)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-replace-this

# ── Server Port ────────────────────────────────────
PORT=3001

# ── CORS ───────────────────────────────────────────
# Your Vercel frontend URL (no trailing slash)
CORS_ORIGIN=https://your-app.vercel.app
